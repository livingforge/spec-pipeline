{#-
  jp-sier-std システム基本設計書（Excel 風 HTML）

  block 規約（設計メモ §6.3）に従い、標準 block
    cover / revision_history / toc / preface / chapters / appendix
  を定義する。消費側プロジェクトは
    {% extends "std/basic-design.html.j2" %}
    {% block preface %}…独自の前書き…{% endblock %}
  の形で必要な章だけ差し替えられる（全置換は STD-W303 で可視化）。

  ドメイン種別（jp-sier-std/metamodel/core.yaml）:
    screen / entity / data-item / business-rule / external-interface
-#}
{% import "_house-style.html.j2" as ex %}
{% set screens = store.items_of('screen') %}
{% set entities = store.items_of('entity') %}
{# 業務ルールは rule_kind で振り分ける。基本設計書は business（＋未設定は既存
   データ保護のため残す）と calculation（計算仕様）のみを載せ、実装層
   （validation / processing / default / error）は詳細設計書へ回す（P1-1）。 #}
{% set rules = store.items_of('business-rule')|by_rule_kind(['business'], keep_unset=true) %}
{% set calc_rules = store.items_of('business-rule')|by_rule_kind(['calculation']) %}
{% set ifaces = store.items_of('external-interface') %}
{{ ex.page_start(doc.title) }}

{% block cover %}
{{ ex.cover(doc.title, doc.doc_no, doc.version, generated_at[:10],
            doc.get('org', ''), doc.get('preface', {}).get('purpose', '')) }}
{% endblock %}

{% block revision_history %}
{% call ex.sheet('改訂履歴', doc.title, doc.doc_no, doc.version) %}
{% if data_history %}
{% set rows = [] %}
{% for h in data_history %}
{% set _ = rows.append({'version': loop.index, 'date': h.date,
    'note': (h.subject ~ '：' if h.subject and not h.initial else '') ~ h.summary
            ~ '（' ~ (h.short if h.short else '未コミット') ~ '）',
    'author': h.author}) %}
{% endfor %}
{{ ex.rev_history(rows) }}
{% else %}
{{ ex.rev_history([{'version': doc.version, 'date': generated_at[:10],
    'note': '初版（データ版 ' ~ data_rev ~ ' から自動生成）', 'author': 'contextdb'}]) }}
{% endif %}
{% endcall %}
{% endblock %}

{% block toc %}
{% call ex.sheet('目次', doc.title, doc.doc_no, doc.version) %}
{{ ex.toc([
  {'no': '1',   'sheet': '1. 概要',          'desc': '目的・対象範囲・前提'},
  {'no': '2',   'sheet': '2. 画面一覧',      'desc': '画面の一覧と表示項目'},
  {'no': '3',   'sheet': '3. テーブル一覧',  'desc': 'エンティティ（テーブル）と列'},
  {'no': '4',   'sheet': '4. 業務ルール',    'desc': '業務ルールと制約対象'},
  {'no': '5',   'sheet': '5. 外部インターフェース', 'desc': '外部連携の一覧'},
  {'no': '付録', 'sheet': '付録 出典一覧',   'desc': '各記載の出典（元資料・箇所・原文）'},
]) }}
{% endcall %}
{% endblock %}

{% block preface %}
{% call ex.sheet('1. 概要', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('1.1', '目的') }}
{{ ex.prose(doc.preface.purpose) }}
{{ ex.sec('1.2', '対象範囲') }}
{{ ex.prose(doc.preface.scope) }}
{% if doc.preface.get('premise') %}
{{ ex.sec('1.3', '前提') }}
{{ ex.prose(doc.preface.premise) }}
{% endif %}
{% endcall %}
{% endblock %}

{% block chapters %}
{# ---- 2. 画面一覧 ---- #}
{% call ex.sheet('2. 画面一覧', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('2', '画面一覧') }}
<table class="xl">
  <tr><th style="width:12%">画面ID</th><th style="width:22%">画面名</th>
      <th style="width:10%">種別</th><th style="width:8%">項目数</th><th>説明</th></tr>
  {% for s in screens %}
  <tr>
    <td class="c">{{ s.attrs.screen_id }}</td><td>{{ s.attrs.name }}</td>
    <td class="c">{{ s.attrs.get('screen_type', '—') }}</td>
    <td class="num">{{ store.relations_of('displays', src=s.id)|length }}</td>
    <td>{{ s.attrs.description }}</td>
  </tr>
  {% endfor %}
</table>
{% endcall %}
{# ---- 3. テーブル一覧 ---- #}
{% call ex.sheet('3. テーブル一覧', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('3', 'テーブル一覧') }}
{% for e in entities %}
{{ ex.subsec('3.' ~ loop.index, e.attrs.name ~ '（' ~ e.attrs.physical_name ~ '）') }}
{% if e.attrs.get('description') %}{{ ex.prose(e.attrs.description) }}{% endif %}
<table class="xl">
  <tr><th style="width:6%">PK</th><th style="width:24%">論理名</th>
      <th style="width:24%">物理名</th><th style="width:12%">型</th><th>必須</th></tr>
  {% for c in store.relations_of('has-column', src=e.id) %}
  {% set di = store.items[c.dst] %}
  <tr>
    <td class="c">{{ '●' if c.attrs.get('pk') else '' }}</td>
    <td>{{ di.attrs.name }}</td><td>{{ c.attrs.physical_name }}</td>
    <td class="c">{{ di.attrs.type }}{{ '(' ~ di.attrs.length ~ ')' if di.attrs.get('length') else '' }}</td>
    <td class="c">{{ '○' if c.attrs.get('required') else '' }}</td>
  </tr>
  {% endfor %}
</table>
{% endfor %}
{% endcall %}
{# ---- 4. 業務ルール（大分類(category)で見出しを束ねる。未設定は末尾の未分類） ---- #}
{% call ex.sheet('4. 業務ルール', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('4', '業務ルール') }}
{% for cat, rows in rules|group_by('category') %}
{{ ex.subsec('4.' ~ loop.index, cat) }}
<table class="xl">
  <tr><th style="width:14%">ルールID</th><th>内容</th><th style="width:24%">制約対象</th></tr>
  {% for r in rows %}
  <tr>
    <td class="c">{{ r.attrs.rule_id }}</td><td>{{ r.attrs.statement }}</td>
    <td>{% for c in store.relations_of('constrains', src=r.id) %}{{ c.dst|item_label }}{{ '、' if not loop.last }}{% endfor %}</td>
  </tr>
  {% endfor %}
</table>
{% endfor %}
{% if not rules %}{{ ex.prose('業務判断のルールは登録されていません。') }}{% endif %}
{# 計算仕様（rule_kind: calculation）。算出ルール・計算式は業務ルールと分けて示す。 #}
{% if calc_rules %}
{{ ex.subsec('4.計', '計算仕様') }}
<table class="xl">
  <tr><th style="width:14%">ルールID</th><th>算出内容</th><th style="width:24%">対象</th></tr>
  {% for r in calc_rules %}
  <tr>
    <td class="c">{{ r.attrs.rule_id }}</td><td>{{ r.attrs.statement }}</td>
    <td>{% for c in store.relations_of('constrains', src=r.id) %}{{ c.dst|item_label }}{{ '、' if not loop.last }}{% endfor %}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}
{% endcall %}
{# ---- 5. 外部インターフェース（方向(direction)で見出しを束ねる） ---- #}
{% call ex.sheet('5. 外部インターフェース', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('5', '外部インターフェース') }}
{% for dir, rows in ifaces|group_by('direction') %}
{{ ex.subsec('5.' ~ loop.index, dir) }}
<table class="xl">
  <tr><th style="width:12%">IF-ID</th><th style="width:24%">名称</th>
      <th style="width:16%">プロトコル</th><th>説明</th></tr>
  {% for i in rows %}
  <tr>
    <td class="c">{{ i.attrs.if_id }}</td><td>{{ i.attrs.name }}</td>
    <td class="c">{{ i.attrs.get('protocol', '—') }}</td>
    <td>{{ i.attrs.description }}</td>
  </tr>
  {% endfor %}
</table>
{% endfor %}
{% endcall %}
{% endblock %}

{% block appendix %}
{% call ex.sheet('付録 出典一覧', doc.title, doc.doc_no, doc.version) %}
{{ ex.sec('付録', '出典一覧') }}
{% set rows = [] %}
{% for it in screens + entities + rules + calc_rules + ifaces %}
{% if it.source %}{% set _ = rows.append({'name': it.label(mm), 'kind': mm.item_types[it.type].label,
    'id': it.id, 'src': it.source}) %}{% endif %}
{% endfor %}
{% if rows %}{{ ex.appendix_sources(rows) }}{% else %}{{ ex.prose('出典の登録はありません。') }}{% endif %}
{% endcall %}
{% endblock %}

{{ ex.page_end() }}
