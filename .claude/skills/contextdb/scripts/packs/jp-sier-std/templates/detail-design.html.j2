{#-
  jp-sier-std 詳細設計書（Excel 風 HTML・自動生成）

  基本設計書と体裁（_house-style）を揃えた納品用 HTML。非 abstract の台帳文書で
  パラメータは任意（doc.get で受ける）。block 未使用のため block 規約の対象外。
  ドメイン種別: module（クラス）/ method。refines・realizes・has-method を伴う。
-#}
{% import "_house-style.html.j2" as ex %}
{% set modules = store.items_of('module') %}
{# 実装層のルール（rule_kind: validation / processing / default / error）は
   基本設計書の業務ルール章ではなく詳細設計書で受ける（P1-1）。 #}
{% set impl_rules = store.items_of('business-rule')
     |by_rule_kind(['validation', 'processing', 'default', 'error']) %}
{% set _rk_label = {'validation': 'バリデーション一覧', 'processing': 'モジュール仕様（処理順序・アルゴリズム）',
                    'default': 'パラメータ定義（既定値・閾値・上限）', 'error': 'エラー処理一覧'} %}
{{ ex.page_start(doc.title) }}

{# ---- 表紙 ---- #}
{{ ex.cover(doc.title, doc.get('doc_no', ''), doc.get('version', ''),
            generated_at[:10], doc.get('org', '')) }}

{# ---- 改訂履歴 ---- #}
{% call ex.sheet('改訂履歴', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{% if data_history %}
{% set rows = [] %}
{% for h in data_history %}
{% set _ = rows.append({'version': loop.index, 'date': h.date,
    'note': (h.subject ~ '：' if h.subject and not h.initial else '') ~ h.summary
            ~ '（' ~ (h.short if h.short else '未コミット') ~ '）',
    'author': h.author}) %}
{% endfor %}
{{ ex.rev_history(rows) }}
{% else %}
{{ ex.rev_history([{'version': doc.get('version', '1.0'), 'date': generated_at[:10],
    'note': '初版（データ版 ' ~ data_rev ~ ' から自動生成）', 'author': 'contextdb'}]) }}
{% endif %}
{% endcall %}

{# ---- 目次 ---- #}
{% call ex.sheet('目次', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{{ ex.toc([
  {'no': '1',   'sheet': '1. モジュール一覧', 'desc': 'クラスの責務・レイヤ・パッケージ'},
  {'no': '2',   'sheet': '2. メソッド仕様',   'desc': 'クラスごとのメソッドと処理概要・トレース'},
  {'no': '3',   'sheet': '3. ルール仕様',     'desc': 'バリデーション・処理順序・既定値・エラー処理'},
  {'no': '付録', 'sheet': '付録 出典一覧',     'desc': 'モジュール・メソッド・ルールの出典'},
]) }}
{% endcall %}

{# ---- 1. モジュール一覧 ---- #}
{% call ex.sheet('1. モジュール一覧', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{{ ex.sec('1', 'モジュール一覧') }}
<table class="xl">
  <tr><th style="width:12%">モジュールID</th><th style="width:22%">クラス名</th>
      <th style="width:12%">レイヤ</th><th style="width:22%">パッケージ</th><th>責務</th></tr>
  {% for m in modules %}
  <tr>
    <td class="c">{{ m.attrs.module_id }}</td><td>{{ m.attrs.class_name }}</td>
    <td class="c">{{ m.attrs.get('layer', '—') }}</td><td>{{ m.attrs.get('package', '—') }}</td>
    <td>{{ m.attrs.description }}</td>
  </tr>
  {% endfor %}
  {% if not modules %}<tr><td colspan="5">モジュールは登録されていません。</td></tr>{% endif %}
</table>
{% endcall %}

{# ---- 2. メソッド仕様（モジュールごとに責務・トレース・メソッド表） ---- #}
{% call ex.sheet('2. メソッド仕様', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{{ ex.sec('2', 'メソッド仕様') }}
{% for m in modules %}
{{ ex.subsec('2.' ~ loop.index, m.attrs.module_id ~ '　' ~ m.attrs.class_name) }}
{% set realized = store.relations_of('realizes', src=m.id)|map(attribute='dst')|map('item_label')|join('、') %}
{% set refined = store.relations_of('refines', src=m.id)|map(attribute='dst')|map('item_label')|join('、') %}
{{ ex.kv([('責務', m.attrs.description),
          ('レイヤ', m.attrs.get('layer', '—')),
          ('パッケージ', m.attrs.get('package', '—')),
          ('実現する要件', realized or '—'),
          ('詳細化する基本設計', refined or '—')]) }}
{% set methods = store.relations_of('has-method', src=m.id) %}
{% if methods %}
<table class="xl">
  <tr><th style="width:12%">メソッドID</th><th style="width:40%">シグネチャ</th><th>説明</th></tr>
  {% for h in methods %}
  {% set mt = store.items[h.dst] %}
  <tr>
    <td class="c">{{ mt.attrs.method_id }}</td>
    <td><code>{{ mt.attrs.signature }}</code></td>
    <td>{{ mt.attrs.description }}</td>
  </tr>
  {% endfor %}
</table>
{% else %}
{{ ex.prose('処理仕様の記載があるメソッドはありません。') }}
{% endif %}
{% endfor %}
{% if not modules %}{{ ex.prose('モジュールは登録されていません。') }}{% endif %}
{% endcall %}

{# ---- 3. ルール仕様（実装層。rule_kind ごとに束ねる） ---- #}
{% call ex.sheet('3. ルール仕様', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{{ ex.sec('3', 'ルール仕様') }}
{% for kind, rows in impl_rules|group_by('rule_kind') %}
{{ ex.subsec('3.' ~ loop.index, _rk_label.get(kind, kind)) }}
<table class="xl">
  <tr><th style="width:14%">ルールID</th><th>内容</th><th style="width:24%">対象</th></tr>
  {% for r in rows %}
  <tr>
    <td class="c">{{ r.attrs.rule_id }}</td><td>{{ r.attrs.statement }}</td>
    <td>{% for c in store.relations_of('constrains', src=r.id) %}{{ c.dst|item_label }}{{ '、' if not loop.last }}{% endfor %}</td>
  </tr>
  {% endfor %}
</table>
{% endfor %}
{% if not impl_rules %}{{ ex.prose('実装層のルール（rule_kind）は登録されていません。') }}{% endif %}
{% endcall %}

{# ---- 付録 出典一覧（モジュール + メソッド + ルール） ---- #}
{% call ex.sheet('付録 出典一覧', doc.title, doc.get('doc_no', ''), doc.get('version', '')) %}
{{ ex.sec('付録', '出典一覧') }}
{% set rows = [] %}
{% for m in modules %}
{% if m.source %}{% set _ = rows.append({'name': m.label(mm), 'kind': mm.item_types[m.type].label,
    'id': m.id, 'src': m.source}) %}{% endif %}
{% for h in store.relations_of('has-method', src=m.id) %}
{% set mt = store.items[h.dst] %}
{% if mt.source %}{% set _ = rows.append({'name': mt.label(mm), 'kind': mm.item_types[mt.type].label,
    'id': mt.id, 'src': mt.source}) %}{% endif %}
{% endfor %}
{% endfor %}
{% if rows %}{{ ex.appendix_sources(rows) }}{% else %}{{ ex.prose('出典の登録はありません。') }}{% endif %}
{% endcall %}

{{ ex.page_end() }}
